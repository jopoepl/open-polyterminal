# Optional: add your own weather provider keys if you extend the API routes.
# WEATHER_DOTCOM_API_KEY=

# Q&A provider switch (default is claude)
# AI_PROVIDER=claude
# AI_TIMEOUT_MS=30000
# CODEX_MODEL=o3
# CODEX_BIN=codex
# CLAUDE_BIN=claude

# MCP server controls (set *_ENABLED=0 to disable)
# WEATHER_MCP_URL=http://127.0.0.1:8787/mcp
# WEATHER_MCP_DEFAULT_URL=http://127.0.0.1:8787/mcp
# POLYMARKET_MCP_URL=http://127.0.0.1:8788/mcp
# NEWS_MCP_URL=http://127.0.0.1:8789/mcp

# Optional MCP process tuning
# WEATHER_MCP_STARTUP_TIMEOUT_SEC=45
# WEATHER_MCP_TOOL_TIMEOUT_SEC=45
# POLYMARKET_MCP_STARTUP_TIMEOUT_SEC=45
# POLYMARKET_MCP_TOOL_TIMEOUT_SEC=45
# NEWS_MCP_STARTUP_TIMEOUT_SEC=45
# NEWS_MCP_TOOL_TIMEOUT_SEC=45

# News API base for news MCP (defaults to GDELT)
# NEWS_API_BASE_URL=https://api.gdeltproject.org/api/v2/doc/doc

# Disable runtime MCP probing once URLs are known-good (set to 1 to skip)
# MCP_SKIP_RUNTIME_PROBE=1
